# Every variable below is required at startup — config.ts will throw if any are missing.
# Replace placeholder UUIDs with your real YNAB ids before running.

# --- YNAB ---
# Personal Access Token
YNAB_TOKEN=

# Budget id
YNAB_BUDGET_ID=00000000-0000-0000-0000-000000000000

# JSON object of allowlisted account ids. Keys are documentation; values matter.
ALLOWED_ACCOUNT_IDS={"example_card":"11111111-1111-1111-1111-111111111111"}

# --- Workflow ---
# Days back to scan for new transactions (overridable via --lookback-days). Bump
# higher (e.g. 14) if you ever go more than a few days without running the job.
LOOKBACK_DAYS=3

# JSONL audit log directory (relative paths resolve from CWD)
AUDIT_DIR=audit

# Category groups to drop from the prompt (YNAB API returns them, but the LLM
# shouldn't pick from them). JSON array of strings.
EXCLUDED_CATEGORY_GROUPS=["Credit Card Payments"]

# Routing nudges fed to the LLM. JSON array of strings — each becomes a numbered
# rule in the prompt. Use these to teach the model how YOUR categories map to
# common purchases. Phrasing is loose; the LLM matches on intent.
# Example: ["Pet items go to \"Pet Care\".", "Coffee goes to \"Dining Out\"."]
CATEGORY_ROUTING_HINTS=[]

# --- Anthropic ---
# API key — get one at https://console.anthropic.com (separate from Claude Pro).
ANTHROPIC_API_KEY=

# Model id. Haiku 4.5 is cheap and accurate enough for this classification task.
ANTHROPIC_MODEL=claude-haiku-4-5
